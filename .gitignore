__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/
*.egg

# ── 虚拟环境 ──
.venv/
venv/
env/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.opencode/
.trae/

# ── 操作系统 ──
.DS_Store
Thumbs.db
desktop.ini

# ── AstrBot / Quill 插件用户数据（含隐私） ──
imports/
data/

# ── MCP 配置（可能含 API Key） ──
.mcp.json
.mcp/

# ── 环境变量 / 密钥 ──
