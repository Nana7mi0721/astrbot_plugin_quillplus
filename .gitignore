.env.*
*.pem
*.key

# ── 临时/备份文件 ──
*.tmp
*.bak
*.log
logs/
_commit_msg.txt

# ── 排除 __pycache__ 下的 .pyc（双重保险） ──
*.pyc

# ── 测试产物 ──
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── 确保示例文件永远被追踪（不允许被上方规则误排除）──
!worldbooks/
!knowledge/
